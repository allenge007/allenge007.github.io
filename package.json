{
  "name": "allenge-personal-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "build:astro": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "build:notes": "node scripts/prepare-notes.mjs && mkdocs build --site-dir dist/notes",
    "build:search": "pagefind --site dist",
    "build": "npm run build:astro && npm run build:notes && node scripts/postbuild.mjs && npm run build:search",
    "test:links": "node scripts/check-links.mjs",
    "test:content": "node scripts/check-content-contracts.mjs",
    "verify": "npm run check && npm run build && npm run test:links && npm run test:content"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/solway": "^5.2.8",
    "astro": "^7.0.9",
    "katex": "^0.17.0",
    "mermaid": "^11.16.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "pagefind": "^1.5.2",
    "typescript": "^6.0.3"
  }
}
