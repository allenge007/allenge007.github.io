---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AboutMascot from '../../../components/AboutMascot.astro';
import { profileContent, siteConfig } from '../../../../site.config';
const flags = siteConfig.sectionFlags;
---
<BaseLayout locale="en" title="Research & Study" description="Research interests, methods, coursework, and competitive programming during undergraduate study." alternatePath="/about/" alternateLocale="zh">
  <article class="about-page shell">
    <header class="about-hero" data-reveal>
      <div class="about-hero-copy">
        <p class="section-kicker">About</p>
        <h1>Research & Study</h1>
        <p>I’m a computer science undergraduate at Sun Yat-sen University and a former competitive programmer. I’m interested in AI systems that are efficient, trustworthy, and useful in practice—especially research agents, executable multimodal reasoning, and learning-based decision systems.</p>
        <div class="hero-actions">
          <a class="button button-primary" href={`mailto:${siteConfig.social.email}`}>Email me</a>
          <a class="button button-quiet" href={siteConfig.social.github}>GitHub ↗</a>
        </div>
      </div>
      <AboutMascot locale="en" />
    </header>

    <div class="about-grid">
      {flags.education && <section data-reveal><p class="section-kicker">Background</p><h2>Undergraduate Computer Science</h2><p>I’m pursuing a B.Eng. in Computer Science and Technology at Sun Yat-sen University (2023–2027 expected). My coursework spans algorithms, operating systems, networks, databases, machine learning, and optimization. IELTS Academic: 7.0.</p></section>}
      {flags.research && <section data-reveal><p class="section-kicker">Research</p><h2>Research Agents & Executable Reasoning</h2><p>A manuscript describing IDAgent is in preparation. The system connects research ideas with datasets through retrieval, adaptation, and reflection. GeoSketch-CoT turns geometry reasoning steps into editable SVG scratchpads. IDAgent is presented here as work in progress, not as a publication.</p></section>}
      {flags.honors && <section data-reveal><p class="section-kicker">Contests</p><h2>Competitive Programming</h2><p>My awards include a silver medal at the ICPC Asia Regional in Shanghai, a gold medal at the CCPC National Invitational in Guangdong, a silver medal at the CCF CAT Finals, and two first prizes at the SYSU Programming Contest.</p></section>}
      {flags.skills && <section data-reveal><p class="section-kicker">Methods</p><h2>Methods & Tools</h2><p>I work mainly with Python, C++, and PyTorch, alongside RAG, Faiss, CUDA, MPI, and Docker. Beyond the stack, I care about experiment design, reproducible evaluation, and making complex processes legible.</p></section>}
    </div>

    {(flags.education || (flags.honors && profileContent.honors.length > 0)) && <section class="about-honors" data-reveal aria-labelledby="about-honors-heading">
      <p class="section-kicker">Background</p>
      <h2 id="about-honors-heading">Education & honors</h2>
      {flags.education && <div class="education-card">
        <span class="education-period">{profileContent.education.period}</span>
        <div><h3>{profileContent.education.degree.en}</h3><p class="education-school">{profileContent.education.school.en}</p><p>{profileContent.education.detail.en}</p></div>
      </div>}
      {flags.honors && profileContent.honors.length > 0 && <ol class="honors-list">{profileContent.honors.map((honor) => <li><time>{honor.date}</time><span>{honor.title.en}</span></li>)}</ol>}
    </section>}
  </article>
</BaseLayout>
