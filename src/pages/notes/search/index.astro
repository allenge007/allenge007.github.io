---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/notes.css';
---

<BaseLayout
  locale="zh"
  title="搜索 Notes"
  description="检索数学、计算机科学与课程 Notes。"
  canonicalPath="/notes/search/"
  pagefind={false}
>
  <section class="notes-search-page shell reading-shell">
    <nav class="notes-breadcrumbs" aria-label="面包屑"><a href="/notes/">Notes</a><span aria-hidden="true">/</span><span>搜索</span></nav>
    <header>
      <p class="section-kicker">Notes Search</p>
      <h1>在 Notes 中检索</h1>
      <p>结果仅来自数学、计算机科学与课程笔记；文章和项目请使用<a href="/search/">全站搜索</a>。</p>
    </header>
    <div id="notes-pagefind-search" class="pagefind-host" aria-live="polite">
      <p data-search-status>正在加载搜索索引…</p>
    </div>
  </section>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    addEventListener('DOMContentLoaded', () => {
      const host = document.querySelector('#notes-pagefind-search');
      const status = host?.querySelector('[data-search-status]');
      try {
        if (typeof window.PagefindUI !== 'function') throw new Error('Pagefind UI is unavailable.');
        status?.remove();
        const search = new window.PagefindUI({
          element: '#notes-pagefind-search',
          showSubResults: true,
          showImages: false,
          resetStyles: false,
          showEmptyFilters: false,
          translations: {
            placeholder: '搜索 Notes',
            zero_results: '没有找到“[SEARCH_TERM]”',
            many_results: '找到 [COUNT] 条 Notes 结果',
            one_result: '找到 1 条 Notes 结果',
            clear_search: '清除',
            load_more: '加载更多',
          },
        });
        search.triggerFilters({ kind: 'notes' });
      } catch (error) {
        if (host) host.innerHTML = '<p>搜索索引会在完整生产构建后生成。</p>';
      }
    });
  </script>
</BaseLayout>
