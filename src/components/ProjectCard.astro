---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../../site.config';

interface Props {
  project: CollectionEntry<'projects'>;
  locale: Locale;
  compact?: boolean;
}

const { project, locale, compact = false } = Astro.props;
const href = `${locale === 'en' ? '/en' : ''}/projects/${project.data.slug}/`;
const hasThemePair = Boolean(project.data.image && project.data.imageDark);
---

<article class:list={['project-card', compact && 'project-card-compact']} data-reveal>
  {project.data.image && (
    <div class="project-card-image" data-image-shell>
      <img
        src={project.data.image}
        alt={project.data.imageAlt?.[locale] ?? ''}
        loading="lazy"
        decoding="async"
        data-theme-image={hasThemePair ? 'light' : 'all'}
        data-fallback-image
      />
      {project.data.imageDark && (
        <img
          src={project.data.imageDark}
          alt={project.data.imageAlt?.[locale] ?? ''}
          loading="lazy"
          decoding="async"
          data-theme-image="dark"
          data-fallback-image
        />
      )}
    </div>
  )}
  <div class="project-card-topline">
    <span>{project.data.date}</span>
    <span>{project.data.status[locale]}</span>
  </div>
  <h3><a href={href}>{project.data.title[locale]}</a></h3>
  <p class="project-problem">{project.data.problem[locale]}</p>
  {!compact && <p>{project.data.summary[locale]}</p>}
  {!compact && project.data.metrics.length > 0 && (
    <dl class="project-card-metrics">
      {project.data.metrics.slice(0, 3).map((metric) => <div><dt>{metric.value}</dt><dd>{metric.label[locale]}</dd></div>)}
    </dl>
  )}
  <ul class="tag-list" aria-label="Tech stack">
    {project.data.stack.slice(0, compact ? 4 : 7).map((item) => <li>{item}</li>)}
  </ul>
  <a class="text-link" href={href}>{locale === 'zh' ? '查看方法与结果' : 'View approach and outcome'} <span aria-hidden="true">↗</span></a>
</article>
