---
import type { CollectionEntry } from 'astro:content';
import { profileContent, siteConfig, type Locale } from '../../site.config';
import HeroVisual from './HeroVisual.astro';
import ProjectCard from './ProjectCard.astro';
import PostCard from './PostCard.astro';
import PhotosBand from './PhotosBand.astro';

interface Props {
  locale: Locale;
  projects: CollectionEntry<'projects'>[];
  posts: CollectionEntry<'posts'>[];
}

const { locale, projects, posts } = Astro.props;
const flags = siteConfig.sectionFlags;
const featuredProjects = projects.filter((project) => project.data.featured).slice(0, 3);
const recentPosts = posts.slice(0, 3);
const contactLabel = locale === 'zh' ? '写邮件' : 'Email me';
---

<section class="hero shell">
  <div class="hero-copy" data-reveal>
    <p class="hero-eyebrow">{profileContent.hero.eyebrow[locale]}</p>
    <h1>{profileContent.hero.title[locale]}</h1>
    <p class="hero-school">{siteConfig.identity.school[locale]}</p>
    <p class="hero-intro">{profileContent.hero.intro[locale]}</p>
    <div class="hero-actions">
      <a class="button button-primary" href={siteConfig.social.github}>GitHub <span aria-hidden="true">↗</span></a>
      <a class="button button-quiet" href={`mailto:${siteConfig.social.email}`}>{contactLabel}</a>
    </div>
    <dl class="hero-facts">
      <div><dt>{locale === 'zh' ? '关注方向' : 'Focus'}</dt><dd>{siteConfig.identity.direction[locale]}</dd></div>
      <div><dt>{locale === 'zh' ? '坐标' : 'Based in'}</dt><dd>{siteConfig.identity.location[locale]}</dd></div>
    </dl>
  </div>
  <HeroVisual locale={locale} />
</section>

{flags.research && profileContent.research.length > 0 && (
  <section class="section shell" aria-labelledby="research-heading">
    <div class="section-heading" data-reveal>
      <div>
        <p class="section-kicker">Research</p>
        <h2 id="research-heading">{locale === 'zh' ? '检索、推理与决策' : 'Retrieval, Reasoning & Decision-Making'}</h2>
      </div>
      <p>{locale === 'zh' ? '比起一张漂亮的最终分数表，我更想知道系统如何工作、为何有效，结果能否复现。' : 'I care about how a system works, why it works, and whether its results can be reproduced—not just the final score.'}</p>
    </div>
    <div class="interest-grid">
      {profileContent.research.map((interest) => (
        <article class="interest-card" data-reveal>
          <span class="interest-index">{interest.index}</span>
          <h3>{interest.title[locale]}</h3>
          <p>{interest.description[locale]}</p>
        </article>
      ))}
    </div>
  </section>
)}

{flags.skills && profileContent.skills.length > 0 && (
  <section class="section shell skills-section" aria-labelledby="skills-heading">
    <div class="section-heading slim-heading" data-reveal>
      <div>
        <p class="section-kicker">Methods</p>
        <h2 id="skills-heading">{locale === 'zh' ? '方法、系统与工程' : 'Methods, Systems & Engineering'}</h2>
      </div>
    </div>
    <div class="skills-grid">
      {profileContent.skills.map((group) => (
        <div class="skill-group" data-reveal>
          <h3>{group.title[locale]}</h3>
          <p>{group.items.join(' · ')}</p>
        </div>
      ))}
    </div>
  </section>
)}

{flags.education && (
  <section class="section shell cv-section" aria-labelledby="education-heading">
    <div class="cv-title" data-reveal>
      <p class="section-kicker">Background</p>
      <h2 id="education-heading">{locale === 'zh' ? '本科教育与竞赛经历' : 'Undergraduate Study & Honors'}</h2>
    </div>
    <div class="education-card" data-reveal>
      <span class="education-period">{profileContent.education.period}</span>
      <div>
        <h3>{profileContent.education.degree[locale]}</h3>
        <p class="education-school">{profileContent.education.school[locale]}</p>
        <p>{profileContent.education.detail[locale]}</p>
      </div>
    </div>
    {flags.honors && profileContent.honors.length > 0 && (
      <ol class="honors-list">
        {profileContent.honors.map((honor) => (
          <li data-reveal><time>{honor.date}</time><span>{honor.title[locale]}</span></li>
        ))}
      </ol>
    )}
  </section>
)}

{flags.projects && featuredProjects.length > 0 && (
  <section class="section shell" aria-labelledby="projects-heading">
    <div class="section-heading" data-reveal>
      <div>
        <p class="section-kicker">Projects</p>
        <h2 id="projects-heading">{locale === 'zh' ? '研究原型与系统实现' : 'Research Prototypes & Systems'}</h2>
      </div>
      <a class="text-link heading-link" href={locale === 'zh' ? '/projects/' : '/en/projects/'}>{locale === 'zh' ? '全部项目' : 'All projects'} <span aria-hidden="true">→</span></a>
    </div>
    <div class="project-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} locale={locale} compact />)}
    </div>
  </section>
)}

{flags.posts && recentPosts.length > 0 && (
  <section class="section shell" aria-labelledby="posts-heading">
    <div class="section-heading" data-reveal>
      <div>
        <p class="section-kicker">Writing</p>
        <h2 id="posts-heading">{locale === 'zh' ? '技术笔记与日常记录' : 'Technical Notes & Everyday Writing'}</h2>
      </div>
      <a class="text-link heading-link" href={locale === 'zh' ? '/blog/' : '/en/blog/'}>{locale === 'zh' ? '查看归档' : 'Browse archive'} <span aria-hidden="true">→</span></a>
    </div>
    <div class="post-grid">
      {recentPosts.map((post, index) => <PostCard post={post} locale={locale} featured={index === 0} />)}
    </div>
  </section>
)}

{flags.photos && <PhotosBand locale={locale} />}

{flags.notes && (
  <section class="notes-cta shell section" data-reveal aria-labelledby="notes-heading">
    <div>
      <p class="section-kicker">Notes</p>
      <h2 id="notes-heading">{locale === 'zh' ? '数学、系统与 AI Notes' : 'Math, Systems & AI Notes'}</h2>
      <p>{locale === 'zh' ? '课程 Notes 仍完整留在 MkDocs：公式、图表、代码和当时的思路，都维持原来的阅读方式。' : 'My long-running MkDocs notes remain intact, including admonitions, collapsible sections, Mermaid diagrams, KaTeX formulas, and code blocks. Each note stays in its original language.'}</p>
    </div>
    <div class="notes-actions">
      <a class="button button-light" href="/notes/">{locale === 'zh' ? '打开 Notes' : 'Open Notes'} <span aria-hidden="true">↗</span></a>
      <a class="button button-ghost-light" href={locale === 'zh' ? '/search/' : '/en/search/'}>{locale === 'zh' ? '搜索全站' : 'Search the site'}</a>
    </div>
  </section>
)}
