---
import { Picture } from 'astro:assets';
import { selectPhotos } from '../data/photos';
import monthlySalaryCatRunning from '../assets/brand/monthly-salary-cat-sway.gif?url';
import monthlySalaryCatReview from '../assets/brand/monthly-salary-cat-review.gif?url';
import monthlySalaryCatWaving from '../assets/brand/monthly-salary-cat-waving.gif?url';
import monthlySalaryCatJumping from '../assets/brand/monthly-salary-cat-jumping.gif?url';
import monthlySalaryCatStatic from '../assets/brand/monthly-salary-cat-static.webp?url';
import type { Locale } from '../../site.config';

interface Props { locale: Locale }
const { locale } = Astro.props;
const heroPhotos = selectPhotos('hero');
const totalLabel = String(heroPhotos.length).padStart(2, '0');
const labels = locale === 'zh'
  ? {
      region: '生活照片轮播与 Monthly Salary Cat 动画',
      carousel: '生活照片轮播',
      previous: '上一张照片',
      next: '下一张照片',
      pause: '暂停自动轮播',
      play: '继续自动轮播',
      fallback: '渐变图片占位',
      dot: '查看第',
      dotSuffix: '张照片',
      mascot: '月薪猫：移开时摸鱼，悬停或键盘聚焦时工作',
    }
  : {
      region: 'Rotating everyday photographs and a Monthly Salary Cat animation',
      carousel: 'Everyday photograph carousel',
      previous: 'Previous photograph',
      next: 'Next photograph',
      pause: 'Pause automatic rotation',
      play: 'Resume automatic rotation',
      fallback: 'Gradient image placeholder',
      dot: 'Show photograph ',
      dotSuffix: '',
      mascot: 'Monthly Salary Cat: slacking off at rest, working while hovered or keyboard-focused',
    };
---

<div class="hero-visual" data-parallax aria-label={labels.region}>
  <div class="hero-orbit" aria-hidden="true"></div>
  {heroPhotos.length > 0 ? (
    <div
      class="hero-carousel"
      data-hero-carousel
      role="region"
      aria-roledescription={locale === 'zh' ? '轮播' : 'carousel'}
      aria-label={labels.carousel}
      tabindex="0"
    >
      <div class="hero-deck" data-hero-deck>
        {heroPhotos.map((photo, index) => (
          <figure
            class:list={[
              'hero-slide',
              index === 0 && 'is-active',
              index === 1 && 'is-next',
              index === heroPhotos.length - 1 && 'is-previous',
            ]}
            data-hero-slide
            data-index={index}
            aria-hidden={index === 0 ? 'false' : 'true'}
          >
            <div class="hero-slide-frame" data-image-shell>
              <Picture
                src={photo.src}
                alt={photo.alt[locale]}
                widths={[320, 480, 720, 960]}
                sizes="(max-width: 700px) 86vw, (max-width: 1100px) 46vw, 460px"
                formats={['avif', 'webp']}
                fallbackFormat="webp"
                loading={index === 0 ? 'eager' : 'lazy'}
                fetchpriority={index === 0 ? 'high' : 'auto'}
                data-fallback-image
              />
              <figcaption>
                <span>{String(index + 1).padStart(2, '0')}</span>
                {photo.caption[locale]}
              </figcaption>
            </div>
          </figure>
        ))}
      </div>
      <div class="hero-carousel-footer">
        <div class="hero-carousel-status" aria-live="off" aria-atomic="true">
          <span data-hero-current>01</span><span aria-hidden="true">/</span><span>{totalLabel}</span>
        </div>
        <div class="hero-carousel-dots" aria-label={labels.carousel}>
          {heroPhotos.map((_, index) => (
            <button
              type="button"
              data-hero-dot
              data-index={index}
              class:list={[index === 0 && 'is-active']}
              aria-label={`${labels.dot}${index + 1}${labels.dotSuffix}`}
              aria-current={index === 0 ? 'true' : undefined}
            ></button>
          ))}
        </div>
        <div class="hero-carousel-controls">
          <button type="button" data-hero-previous aria-label={labels.previous}><span aria-hidden="true">←</span></button>
          <button
            type="button"
            data-hero-pause
            data-label-pause={labels.pause}
            data-label-play={labels.play}
            aria-label={labels.pause}
            aria-pressed="false"
          ><span data-hero-pause-icon aria-hidden="true">Ⅱ</span></button>
          <button type="button" data-hero-next aria-label={labels.next}><span aria-hidden="true">→</span></button>
        </div>
      </div>
    </div>
  ) : (
    <div class="hero-carousel-empty" aria-label={labels.fallback}><span class="image-fallback"></span></div>
  )}
  <button
    type="button"
    class="mascot-card"
    data-image-shell
    data-mascot
    data-mascot-mode="slack"
    data-mascot-state="waving"
    data-mascot-running={monthlySalaryCatRunning}
    data-mascot-review={monthlySalaryCatReview}
    data-mascot-waving={monthlySalaryCatWaving}
    data-mascot-jumping={monthlySalaryCatJumping}
    aria-label={labels.mascot}
    aria-pressed="false"
  >
    <picture>
      <source media="(prefers-reduced-motion: reduce)" srcset={monthlySalaryCatStatic} type="image/webp" />
      <img
        src={monthlySalaryCatWaving}
        alt=""
        width="192"
        height="208"
        loading="eager"
        decoding="async"
        data-mascot-image
        data-fallback-image
      />
    </picture>
  </button>
</div>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  document.querySelectorAll<HTMLElement>('[data-hero-carousel]').forEach((carousel) => {
    const slides = Array.from(carousel.querySelectorAll<HTMLElement>('[data-hero-slide]'));
    const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>('[data-hero-dot]'));
    const deck = carousel.querySelector<HTMLElement>('[data-hero-deck]');
    const currentLabel = carousel.querySelector<HTMLElement>('[data-hero-current]');
    const previousButton = carousel.querySelector<HTMLButtonElement>('[data-hero-previous]');
    const nextButton = carousel.querySelector<HTMLButtonElement>('[data-hero-next]');
    const pauseButton = carousel.querySelector<HTMLButtonElement>('[data-hero-pause]');
    const pauseIcon = carousel.querySelector<HTMLElement>('[data-hero-pause-icon]');
    if (slides.length < 1) return;

    let activeIndex = 0;
    let timer: number | undefined;
    let userPaused = false;
    let pointerInside = false;
    let focusInside = false;
    let touchStartX: number | undefined;

    const stop = () => {
      if (timer !== undefined) window.clearInterval(timer);
      timer = undefined;
    };

    const canAutoPlay = () => (
      slides.length > 1
      && !reduceMotion.matches
      && !userPaused
      && !pointerInside
      && !focusInside
      && !document.hidden
    );

    const syncPlayback = () => {
      stop();
      if (canAutoPlay()) timer = window.setInterval(() => move(1), 5600);
    };

    const render = () => {
      const previousIndex = (activeIndex - 1 + slides.length) % slides.length;
      const nextIndex = (activeIndex + 1) % slides.length;

      slides.forEach((slide, index) => {
        slide.classList.toggle('is-active', index === activeIndex);
        slide.classList.toggle('is-previous', index === previousIndex);
        slide.classList.toggle('is-next', index === nextIndex);
        slide.setAttribute('aria-hidden', index === activeIndex ? 'false' : 'true');
      });
      dots.forEach((dot, index) => {
        const isActive = index === activeIndex;
        dot.classList.toggle('is-active', isActive);
        if (isActive) dot.setAttribute('aria-current', 'true');
        else dot.removeAttribute('aria-current');
      });
      if (currentLabel) currentLabel.textContent = String(activeIndex + 1).padStart(2, '0');
    };

    const move = (delta: number) => {
      activeIndex = (activeIndex + delta + slides.length) % slides.length;
      render();
    };

    const setPauseButton = () => {
      if (!pauseButton) return;
      const motionPaused = reduceMotion.matches;
      pauseButton.hidden = motionPaused;
      pauseButton.setAttribute('aria-pressed', String(userPaused));
      pauseButton.setAttribute('aria-label', userPaused ? pauseButton.dataset.labelPlay! : pauseButton.dataset.labelPause!);
      if (pauseIcon) pauseIcon.textContent = userPaused ? '▶' : 'Ⅱ';
    };

    previousButton?.addEventListener('click', () => { move(-1); syncPlayback(); });
    nextButton?.addEventListener('click', () => { move(1); syncPlayback(); });
    pauseButton?.addEventListener('click', () => {
      userPaused = !userPaused;
      setPauseButton();
      syncPlayback();
    });
    dots.forEach((dot, index) => dot.addEventListener('click', () => {
      activeIndex = index;
      render();
      syncPlayback();
    }));

    carousel.addEventListener('mouseenter', () => { pointerInside = true; syncPlayback(); });
    carousel.addEventListener('mouseleave', () => { pointerInside = false; syncPlayback(); });
    carousel.addEventListener('focusin', () => { focusInside = true; syncPlayback(); });
    carousel.addEventListener('focusout', () => {
      window.requestAnimationFrame(() => {
        focusInside = carousel.contains(document.activeElement);
        syncPlayback();
      });
    });
    carousel.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') { event.preventDefault(); move(-1); }
      if (event.key === 'ArrowRight') { event.preventDefault(); move(1); }
    });

    deck?.addEventListener('touchstart', (event) => {
      touchStartX = event.changedTouches[0]?.clientX;
      stop();
    }, { passive: true });
    deck?.addEventListener('touchend', (event) => {
      const touchEndX = event.changedTouches[0]?.clientX;
      if (touchStartX !== undefined && touchEndX !== undefined) {
        const distance = touchEndX - touchStartX;
        if (Math.abs(distance) > 42) move(distance > 0 ? -1 : 1);
      }
      touchStartX = undefined;
      syncPlayback();
    }, { passive: true });

    document.addEventListener('visibilitychange', syncPlayback);
    reduceMotion.addEventListener('change', () => { setPauseButton(); syncPlayback(); });
    setPauseButton();
    render();
    syncPlayback();
  });

  document.querySelectorAll<HTMLElement>('[data-mascot]').forEach((mascot) => {
    const image = mascot.querySelector<HTMLImageElement>('[data-mascot-image]');
    if (!image) return;

    const actions = {
      work: [
        ['running', mascot.dataset.mascotRunning],
        ['review', mascot.dataset.mascotReview],
      ],
      slack: [
        ['waving', mascot.dataset.mascotWaving],
        ['jumping', mascot.dataset.mascotJumping],
      ],
    } as const;
    const indices = { work: 0, slack: 0 };
    let mode: keyof typeof actions = 'slack';
    let timer: number | undefined;
    let swapTimer: number | undefined;
    let touchReturnTimer: number | undefined;
    let pointerInside = false;
    let keyboardFocused = false;
    let ignoreNextFocus = false;

    Object.values(actions).flat().forEach(([, source]) => {
      if (!source) return;
      const preload = new Image();
      preload.src = source;
    });

    const stopTimer = () => {
      if (timer !== undefined) window.clearTimeout(timer);
      timer = undefined;
    };

    const showAction = (action: string, source: string | undefined) => {
      if (!source || reduceMotion.matches || mascot.dataset.mascotState === action) return;
      if (swapTimer !== undefined) window.clearTimeout(swapTimer);
      mascot.classList.add('is-switching');
      swapTimer = window.setTimeout(() => {
        image.src = source;
        mascot.dataset.mascotState = action;
        window.requestAnimationFrame(() => mascot.classList.remove('is-switching'));
      }, 90);
    };

    const schedule = () => {
      stopTimer();
      if (reduceMotion.matches || document.hidden) return;
      const delay = mode === 'work'
        ? 4200 + Math.random() * 2200
        : 5600 + Math.random() * 2800;
      timer = window.setTimeout(() => {
        indices[mode] = (indices[mode] + 1) % actions[mode].length;
        const [action, source] = actions[mode][indices[mode]];
        showAction(action, source);
        schedule();
      }, delay);
    };

    const setMode = (nextMode: keyof typeof actions) => {
      mode = nextMode;
      mascot.dataset.mascotMode = nextMode;
      mascot.setAttribute('aria-pressed', String(nextMode === 'work'));
      const [action, source] = actions[nextMode][indices[nextMode]];
      showAction(action, source);
      schedule();
    };

    const returnToSlack = () => {
      if (!pointerInside && !keyboardFocused) setMode('slack');
    };

    mascot.addEventListener('pointerenter', (event) => {
      if (event.pointerType === 'touch') return;
      pointerInside = true;
      setMode('work');
    });
    mascot.addEventListener('pointerleave', (event) => {
      if (event.pointerType === 'touch') return;
      pointerInside = false;
      returnToSlack();
    });
    mascot.addEventListener('pointerdown', (event) => {
      ignoreNextFocus = true;
      window.setTimeout(() => { ignoreNextFocus = false; }, 0);
      if (event.pointerType !== 'touch') return;
      if (touchReturnTimer !== undefined) window.clearTimeout(touchReturnTimer);
      setMode('work');
      touchReturnTimer = window.setTimeout(returnToSlack, 6500);
    });
    mascot.addEventListener('focus', () => {
      if (ignoreNextFocus) {
        ignoreNextFocus = false;
        return;
      }
      keyboardFocused = true;
      setMode('work');
    });
    mascot.addEventListener('blur', () => {
      keyboardFocused = false;
      returnToSlack();
    });
    mascot.addEventListener('click', (event) => {
      if (event.detail !== 0) return;
      if (touchReturnTimer !== undefined) window.clearTimeout(touchReturnTimer);
      setMode('work');
      touchReturnTimer = window.setTimeout(returnToSlack, 6500);
    });

    document.addEventListener('visibilitychange', schedule);
    reduceMotion.addEventListener('change', () => {
      if (reduceMotion.matches) stopTimer();
      else setMode(mode);
    });
    schedule();
  });
</script>
